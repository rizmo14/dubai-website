# WordPress GraphQL endpoint (add when connecting Headless WP)
WP_GRAPHQL_URL=https://your-wordpress-site.com/graphql

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console verification
NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://sbcservicesuae.com
